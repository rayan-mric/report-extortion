# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to GitHub — add it to .gitignore

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:fahadvai01@localhost:5432/crimereport

# AWS S3 credentials (create an IAM user with S3 permissions)
AWS_ACCESS_KEY_ID=access_key_id_here
AWS_SECRET_ACCESS_KEY=secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# URL of your React frontend (used by CORS)
CLIENT_URL=http://localhost:3000

# Port the Express server listens on
PORT=5000
